{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "buildCommand": "pnpm --filter @workspace/passport-verifier build",
  "outputDirectory": "artifacts/passport-verifier/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
